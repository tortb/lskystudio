{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "lsky-batch-upload",
  "version": "1.1.3",
  "description": "兰空图床批量上传工具 - 用于批量上传图片到兰空图床并生成Excel报告",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start-web": "http-server ./web -p 8080",
    "build": "electron-builder --win --x64",
    "build-all": "electron-builder --win --x64 --ia32",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64 --ia32"
  },
  "keywords": [
    "lan-kong",
    "image-hosting",
    "batch-upload",
    "electron"
  ],
  "author": "蜀枕清何 (QQ: 356755331)",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.tortb.lsky",
    "productName": "兰空图床批量上传工具",
    "copyright": "Copyright © 2026 ",
    "directories": {
      "output": "dist"
    },
    "files": [
      "web/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
